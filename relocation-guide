     PAGE 5 — COMMUNITY
  ══════════════════════════════════════════ */
  #p5 { background: var(--white); }
  #p5 .page-inner {
    padding: 28px 40px 24px;
    grid-template-rows: auto 1fr;
    gap: 12px;
    position: relative;
  }

  .comm-left {
    background: var(--navy);
    border-radius: 6px;
    padding: 18px;
    height: 100%;
  }

  /* ══════════════════════════════════════════
     PAGE 6 — SCHOOLS
  ══════════════════════════════════════════ */
  #p6 { background: var(--cream); }
  #p6 .page-inner {
    padding: 28px 40px 24px;
    grid-template-rows: auto 1fr;
    gap: 12px;
    position: relative;
