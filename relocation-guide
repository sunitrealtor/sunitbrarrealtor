    padding: 14px;
  }

  .card-navy {
    background: var(--navy);
    border-radius: 4px;
    padding: 14px;
  }

  .badge {
    display: inline-block;
    font-size: 8px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
