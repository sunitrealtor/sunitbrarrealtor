     PAGE 8 — LOANS + HOW I HELP
  ══════════════════════════════════════════ */
  #p8 { background: var(--cream); }
  #p8 .page-inner {
    padding: 28px 40px 24px;
    grid-template-rows: auto 1fr;
    gap: 12px;
    position: relative;
  }

  .phase-head {
    font-size: clamp(8px, 0.95vw, 11px);
    font-weight: 600;
    color: var(--gold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 8px 0 3px;
  }

  /* ══════════════════════════════════════════
     PAGE 9 — BACK COVER
  ══════════════════════════════════════════ */
  #p9 { background: var(--navy); }
  #p9 .page-inner {
    align-items: center;
    justify-items: center;
    text-align: center;
    padding: 40px;
    position: relative;
    grid-template-rows: 1fr auto 1fr;
  }

  .back-center { grid-row: 2; z-index: 2; }

  /* ── DOTS ── */
  #dots {
    position: fixed;
    bottom: 14px;
    left: 50%;
