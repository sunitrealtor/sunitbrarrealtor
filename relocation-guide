    border-radius: 2px;
    margin-bottom: 4px;
  }

  .bullet {
    font-size: clamp(8px, 0.95vw, 10.5px);
    line-height: 1.6;
    color: var(--text-soft);
    padding-left: 12px;
    position: relative;
    margin-bottom: 3px;
    font-weight: 300;
  }
