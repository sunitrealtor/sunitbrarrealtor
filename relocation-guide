<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --navy: #1B2B4B;
    --navy-mid: #2C4070;
    --navy-light: #3A5080;
    --gold: #B8966E;
    --gold-light: #D4B896;
    --gold-pale: #F5EDE0;
    --cream: #FDFAF6;
    --gray-light: #F4F4F2;
    --gray-mid: #888;
    --text: #2A2A2A;
    --text-soft: #555;
    --white: #fff;
    --teal: #2C6E6A;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Jost', sans-serif;
    background: var(--navy);
    color: var(--text);
    overflow: hidden;
    height: 100vh;
    width: 100vw;
  }

  /* ── NAV ── */
  #nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 52px;
    background: rgba(27,43,75,0.97);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    z-index: 100;
    border-bottom: 1px solid rgba(184,150,110,0.3);
  }

  .nav-brand {
    font-family: 'Cormorant Garamond', serif;
    font-size: 15px;
    color: var(--gold-light);
    letter-spacing: 0.04em;
  }

  .nav-controls {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-btn {
    background: none;
    border: 1px solid rgba(184,150,110,0.4);
    color: var(--gold-light);
    padding: 5px 14px;
    border-radius: 3px;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.2s;
  }
  .nav-btn:hover { background: rgba(184,150,110,0.15); border-color: var(--gold); }
  .nav-btn:disabled { opacity: 0.3; cursor: default; }

  #page-counter {
    font-size: 12px;
    color: var(--gold-light);
    min-width: 70px;
    text-align: center;
    letter-spacing: 0.05em;
  }

  /* ── FLIPBOOK CONTAINER ── */
  #book-container {
    position: fixed;
    top: 52px; left: 0; right: 0; bottom: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 2000px;
    background: var(--navy);
    overflow: hidden;
  }

  #book {
    width: 90vw;
    max-width: 1100px;
    height: calc(90vw * 0.5625);
    max-height: calc(100vh - 100px);
    position: relative;
  }

  .page {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    opacity: 0;
    transform: translateX(60px);
    transition: all 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
  }

  .page.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: all;
  }

  .page.exit-left {
    opacity: 0;
    transform: translateX(-60px);
  }

  /* ── SHARED PAGE LAYOUT ── */
  .page-inner {
    width: 100%; height: 100%;
    display: grid;
  }

  .gold-bar-top {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
  }

  .gold-bar-bottom {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 5px;
    background: linear-gradient(90deg, var(--gold), var(--gold-light), var(--gold));
  }

  .page-label {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }

  h1.display {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 600;
    line-height: 1.1;
  }

  h2.section {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(20px, 2.8vw, 34px);
    font-weight: 600;
    line-height: 1.15;
    color: var(--navy);
  }

  h3.sub {
    font-family: 'Jost', sans-serif;
    font-size: clamp(10px, 1.2vw, 13px);
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--navy);
    margin-bottom: 4px;
  }

  p.body-text {
    font-size: clamp(8px, 1vw, 11px);
    line-height: 1.7;
    color: var(--text-soft);
    font-weight: 300;
  }

  .gold-rule {
    height: 1px;
    background: linear-gradient(90deg, var(--gold), transparent);
    margin: 8px 0;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    height: 100%;
  }

  .three-col {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 14px;
