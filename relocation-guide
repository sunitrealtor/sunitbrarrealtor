    padding: 28px 40px 24px;
    grid-template-rows: auto auto 1fr auto;
    gap: 10px;
    position: relative;
  }

  .hood-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
